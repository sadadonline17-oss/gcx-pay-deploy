{
  "services": [
    {
      "name": "backend",
      "root": ".",
      "build": {
        "builder": "NIXPACKS",
        "buildCommand": "pip install -r requirements.txt"
      },
      "deploy": {
        "startCommand": "uvicorn app.main:app --host 0.0.0.0 --port $PORT",
        "healthcheckPath": "/health"
      },
      "variables": {
        "PYTHON_VERSION": "3.9",
        "JWT_EXPIRE_MINUTES": "4320",
        "DATABASE_URL": "sqlite:///./gcx_pay.db",
        "SECRET_KEY": {
          "generator": "RANDOM"
        }
      }
    },
    {
      "name": "frontend",
      "root": "gcx-pay-frontend",
      "build": {
        "builder": "NIXPACKS",
        "buildCommand": "npm ci && npm run build"
      },
      "deploy": {
        "startCommand": "npx serve -s dist -l $PORT"
      },
      "variables": {
        "NODE_VERSION": "18",
        "FRONTEND_URL": "https://frontend.up.railway.app"
      }
    }
  ]
}